FROM try_base_image

# Install necessary packages
RUN apt-get update && apt-get install -y \
    npm \
    vim \ 
    time \
    pre-commit \
    gem

RUN cd ~ && \
    git config --global user.email "you@example.com" && \
    git config --global user.name "Your Name"

# uv-metrics
# COPY   node-sass node-sass
RUN git clone https://github.com/google/uv-metrics
WORKDIR uv-metrics
COPY  uv-metrics/run.sh ./
COPY  uv-metrics/try-run.sh ./
COPY  uv-metrics/run-leak.sh ./
COPY  uv-metrics/try-run-leak.sh ./
RUN chmod +x run.sh try-run.sh
RUN pre-commit install
WORKDIR ../

